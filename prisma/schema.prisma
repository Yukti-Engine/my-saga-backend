generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  name        String
  email       String   @unique
  phone       String?
  star_score  Int      @default(0)
  level       Int      @default(1)
  gems        Int      @default(0)
  accessToken String?  @map("access_token")
  username    String   @unique
  bio         String?  @db.Text
  age         Int?
  gender      String?
  setting_1   Boolean  @default(false)
  setting_2   Boolean  @default(false)
  memberships AdventureMember[]

  @@map("users")
  @@index([username])
}

model Boss {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  phone    String?
  credits  Int     @default(0)
  username String  @unique
  adventures Adventure[]

  @@map("bosses")
}

model Organizer {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  phone    String?
  credits  Int    @default(0)
  username String @unique

  @@map("organizers")
}

model Adventure {
  id        Int               @id @default(autoincrement())
  name      String
  bossId    Int?              @map("boss_id")
  boss      Boss?             @relation(fields: [bossId], references: [id])
  events    Event[]
  members   AdventureMember[]

  @@map("adventures")
}

model Event {
  id           Int        @id @default(autoincrement())
  activity     String
  timing       DateTime   @db.Timestamptz(6)
  venue        String?
  venue_link   String?
  adventureId  Int?       @map("adventure_id")
  adventure    Adventure? @relation(fields: [adventureId], references: [id])

  @@map("events")
  @@index([adventureId])
}

model AdventureMember {
  adventure   Adventure @relation(fields: [adventureId], references: [id])
  adventureId Int       @map("adventure_id")
  user        User      @relation(fields: [userId], references: [id])
  userId      Int       @map("user_id")

  @@id([adventureId, userId])
  @@map("adventure_members")
  @@index([userId])
}

model PendingUser {
  requestId String   @id @map("request_id")
  name      String
  phone     String
  email     String
  dob       String
  gender    String
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)

  @@map("pending_users")
}
