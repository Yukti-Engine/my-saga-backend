# Server
PORT=8080

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Email (Nodemailer)
MY_EMAIL=you@example.com
MY_EMAIL_PASS=your_email_app_password

# SMS (Twilio / FACTOR_SMS)
FACTOR_SMS=your_twilio_api_key

# Google Cloud Storage
GOOGLE_APPLICATION_CREDENTIALS=/app/gcs-credentials.json

# reCAPTCHA
RECAPTCHA_API_KEY=your_recaptcha_secret_key